#!/usr/bin/env python3
"""
auto — runs `claude` or `codex` inside a pseudo-terminal (PTY) and
automatically answers "yes" every time the tool pauses to ask for
confirmation.

Usage:
    auto claude
    auto codex
    auto            # default: claude
    auto update     # self-update via `git pull` in the install directory

Apart from the `update` subcommand, there are no other options and no
alternative command: it just launches the chosen tool and auto-accepts the
confirmation prompts.

Platforms: Linux and macOS use a POSIX PTY (`pty.fork`). Windows uses a
ConPTY pseudoconsole driven through `ctypes` (no third-party dependency;
requires Windows 10 1809+). The prompt-detection logic is shared.

SECURITY WARNING: auto-accepting EVERYTHING also bypasses confirmations for
destructive actions. Prefer running it inside a throwaway directory. See
README.md.
"""

import errno
import os
import re
import subprocess
import sys
import time

POSIX = os.name == "posix"
WINDOWS = os.name == "nt"

if POSIX:
    import fcntl
    import pty
    import select
    import signal
    import struct
    import termios
    import tty

__version__ = "0.1.4"

ENTER = b"\r"

# Supported tools. Each one: a list of (prompt regex, key(s) to send).
# The first rule that matches the visible "tail" of the screen wins.
#
# The leading `[ \t│|]*` tolerates a box border before the arrow/number:
# claude (and others) draw their confirmation menus inside a `│ … │` box, so
# the menu line reads `│ ❯ 1. Yes` rather than starting with the arrow itself.
# Without this, the generic fallback never matches a boxed menu and `auto`
# hangs whenever the question text isn't covered by a tool-specific rule.
YES_MENU_PATTERNS = [
    (r"(?m)^[ \t│|]*[❯›➜→>]\s*(?:\d+[.)]\s*)?Yes\b", ENTER),
    (r"(?m)^[ \t│|]*1[.)]\s*Yes\b[\s\S]*\b2[.)]\s*(?:No|Cancel)\b", ENTER),
]

TOOLS = {
    "claude": [
        (r"Do you want to (proceed|make this edit|create|run)", ENTER),
        *YES_MENU_PATTERNS,
    ],
    "codex": [
        (r"Allow.*\?", ENTER),
        (r"Approve", ENTER),
        *YES_MENU_PATTERNS,
        (r"[\[(]\s*y\s*/\s*n\s*[\])]", b"y\r"),
    ],
}

# Regex that strips ANSI escape sequences (colors, cursor positioning, etc.).
ANSI_RE = re.compile(r"\x1b\[[0-9;?]*[ -/]*[@-~]|\x1b[\(\)][AB012]|\x1b[=>]|\r")

BUFFER_LIMIT = 8192          # raw bytes kept for detection
TAIL_LINES = 12              # how many visible lines to inspect when matching
IDLE_SECS = 0.4              # output inactivity before checking for a prompt
# If a prompt we already answered is still on screen this long after, with no
# output drawn since, the keystroke was almost certainly dropped while the TUI
# was redrawing -- re-send the answer instead of waiting forever.
ANSWER_RETRY_SECS = 1.5
# Bounded re-sends, so a genuinely stuck prompt does not turn into an endless
# stream of keystrokes injected into the tool.
MAX_ANSWER_RETRIES = 2


def resolve_tool(argv):
    """Return the tool name from argv (defaults to "claude").

    argv is expected to look like sys.argv: argv[0] is the program name and
    argv[1], if present, is the tool to run.
    """
    return argv[1] if len(argv) > 1 else "claude"


def compile_patterns(tool):
    """Compile the prompt patterns for a tool into (regex, keys) pairs.

    Raises KeyError if the tool is unknown.
    """
    return [(re.compile(rx, re.IGNORECASE), keys) for rx, keys in TOOLS[tool]]


def strip_ansi(text):
    """Remove ANSI escape sequences and carriage returns from text."""
    return ANSI_RE.sub("", text)


def visible_tail(raw_buffer, tail_lines=TAIL_LINES):
    """Strip ANSI codes and return the last `tail_lines` lines as one string."""
    text = strip_ansi(raw_buffer.decode("utf-8", errors="replace"))
    lines = text.split("\n")
    return "\n".join(lines[-tail_lines:])


def match_prompt(tail, patterns):
    """Return the key(s) to send for the first matching pattern, else None.

    `patterns` is a list of (compiled_regex, keys) pairs, as produced by
    compile_patterns.
    """
    for rx, keys in patterns:
        if rx.search(tail):
            return keys
    return None


class Answerer:
    """Decides what (if anything) to send to an auto-answered tool.

    This is the shared, side-effect-free brain used by both the POSIX and the
    Windows event loops. It keeps just enough state to:

    * avoid re-answering the same unchanged screen on every frame, and
    * re-send the answer a bounded number of times if it never took effect.

    The second point fixes the hang the wrapper used to suffer: the tool's TUI
    occasionally drops a keystroke that arrives while it is repainting, which
    left `auto` blocked forever waiting for output that would never come. When
    the prompt we answered is still on screen and *nothing* has been drawn
    since, we assume the keystroke was lost and send it again.
    """

    def __init__(self, patterns, retry_secs=ANSWER_RETRY_SECS,
                 max_retries=MAX_ANSWER_RETRIES):
        self.patterns = patterns
        self.retry_secs = retry_secs
        self.max_retries = max_retries
        self.answered_tail = None     # the exact screen we last answered
        self.answered_keys = None     # the keys we sent for it (for re-sends)
        self.answered_at = 0.0        # when we last sent them (monotonic)
        self.retries = 0              # re-sends issued for answered_tail

    def reset(self):
        """Forget the last answer; call when the user takes over a prompt."""
        self.answered_tail = None
        self.retries = 0

    def on_idle(self, tail, now):
        """Inspect a settled screen; return keys to send, or None.

        Answers a freshly-appeared prompt once. Returns None when there is no
        prompt or when this exact screen was already answered.
        """
        keys = match_prompt(tail, self.patterns)
        if keys is None:
            self.reset()                       # no prompt on screen anymore
            return None
        if tail == self.answered_tail:
            return None                        # already answered this screen
        self.answered_tail = tail
        self.answered_keys = keys
        self.answered_at = now
        self.retries = 0
        return keys

    def retry_pending(self):
        """Whether a watchdog re-send may still be due (gates the loop wait)."""
        return self.answered_tail is not None and self.retries < self.max_retries

    def on_timeout(self, tail, now, output_since_answer):
        """Re-send the answer if it evidently never took effect, else None.

        Only fires when the answered prompt is still on screen unchanged and no
        output has been drawn since we answered -- the signature of a dropped
        keystroke. `output_since_answer` is True if the tool produced any bytes
        after our last send (in which case the answer clearly registered).
        """
        if not self.retry_pending():
            return None
        if output_since_answer or (now - self.answered_at) < self.retry_secs:
            return None
        if match_prompt(tail, self.patterns) is not None \
                and tail == self.answered_tail:
            self.answered_at = now
            self.retries += 1
            return self.answered_keys
        self.reset()                           # screen changed: answer landed
        return None


def install_dir(path=None):
    """Return the directory of the real `auto` script, resolving symlinks.

    `auto` is typically installed as a symlink on the PATH pointing at a git
    checkout, so the actual repository lives at the symlink's target.
    """
    return os.path.dirname(os.path.realpath(path or __file__))


def update(repo=None, runner=subprocess.call):
    """Self-update the install with `git pull --ff-only`. Return an exit code.

    `repo` defaults to the install directory; `runner` runs the git command
    (injectable for testing). Returns 1 if `repo` is not a git checkout,
    otherwise the exit code reported by git.
    """
    repo = repo if repo is not None else install_dir()
    if not os.path.isdir(os.path.join(repo, ".git")):
        sys.stderr.write(
            f"auto: {repo!r} is not a git checkout; cannot self-update.\n"
        )
        return 1
    return runner(["git", "-C", repo, "pull", "--ff-only"])


# Matches the `__version__ = "X.Y.Z"` assignment so the version can be bumped
# in place (used by the pre-commit hook) without touching the rest of the file.
VERSION_RE = re.compile(r'(?m)^__version__\s*=\s*"(?P<v>\d+\.\d+\.\d+)"')


def bump_version(version, part="patch"):
    """Return `version` (a "MAJOR.MINOR.PATCH" string) with `part` incremented.

    Bumping major resets minor and patch to 0; bumping minor resets patch.
    """
    major, minor, patch = (int(n) for n in version.split("."))
    if part == "major":
        return f"{major + 1}.0.0"
    if part == "minor":
        return f"{major}.{minor + 1}.0"
    if part == "patch":
        return f"{major}.{minor}.{patch + 1}"
    raise ValueError(f"unknown version part: {part!r}")


def bump_source(path=None, part="patch"):
    """Increment the `__version__` string inside the `auto` source file.

    `path` defaults to this script. Returns the new version. Raises ValueError
    if no `__version__` assignment is found.
    """
    path = path if path is not None else os.path.realpath(__file__)
    with open(path, encoding="utf-8") as f:
        text = f.read()
    match = VERSION_RE.search(text)
    if match is None:
        raise ValueError(f"no __version__ string found in {path!r}")
    new_version = bump_version(match.group("v"), part)
    new_text = text[: match.start("v")] + new_version + text[match.end("v") :]
    with open(path, "w", encoding="utf-8") as f:
        f.write(new_text)
    return new_version


def get_winsize(fd):
    """Return the (rows, cols) window size of fd, defaulting to (24, 80)."""
    try:
        data = fcntl.ioctl(fd, termios.TIOCGWINSZ, b"\x00" * 8)
        rows, cols, _, _ = struct.unpack("HHHH", data)
        return rows, cols
    except OSError:
        return 24, 80


def set_winsize(fd, rows, cols):
    """Set the window size of fd to (rows, cols), ignoring errors."""
    try:
        fcntl.ioctl(fd, termios.TIOCSWINSZ, struct.pack("HHHH", rows, cols, 0, 0))
    except OSError:
        pass


def _run_posix(tool, patterns):
    """Run `tool` under a POSIX PTY, auto-answering prompts. Returns an exit code."""
    target = [tool]

    stdin_fd = sys.stdin.fileno()
    stdout_fd = sys.stdout.fileno()

    rows, cols = get_winsize(stdin_fd)

    pid, master_fd = pty.fork()
    if pid == 0:
        # ---- child process ----
        try:
            os.execvp(target[0], target)
        except OSError as e:
            sys.stderr.write(f"auto: could not run {target[0]!r}: {e}\n")
            os._exit(127)

    # ---- parent process ----
    set_winsize(master_fd, rows, cols)

    def handle_winch(signum, frame):
        r, c = get_winsize(stdin_fd)
        set_winsize(master_fd, r, c)

    signal.signal(signal.SIGWINCH, handle_winch)

    old_term = None
    if os.isatty(stdin_fd):
        old_term = termios.tcgetattr(stdin_fd)
        tty.setraw(stdin_fd)

    raw_buffer = bytearray()
    last_output = time.monotonic()
    pending_check = False           # there is new output not yet analyzed
    answerer = Answerer(patterns)   # decides what to send (and when to re-send)
    exit_code = 0

    try:
        while True:
            # Wait for IO, but also wake up periodically so the watchdog can
            # re-send an answer that produced no output (a dropped keystroke).
            if pending_check:
                timeout = IDLE_SECS
            elif answerer.retry_pending():
                timeout = ANSWER_RETRY_SECS
            else:
                timeout = None
            try:
                rlist, _, _ = select.select([stdin_fd, master_fd], [], [], timeout)
            except select.error as e:
                if e.args[0] == errno.EINTR:
                    continue  # interrupted by SIGWINCH; resume
                raise

            if master_fd in rlist:
                try:
                    data = os.read(master_fd, 4096)
                except OSError:
                    data = b""
                if not data:
                    break  # child closed the PTY -> it exited
                os.write(stdout_fd, data)
                raw_buffer.extend(data)
                if len(raw_buffer) > BUFFER_LIMIT:
                    del raw_buffer[:-BUFFER_LIMIT]
                last_output = time.monotonic()
                pending_check = True

            if stdin_fd in rlist:
                try:
                    user_in = os.read(stdin_fd, 4096)
                except OSError:
                    user_in = b""
                if user_in:
                    os.write(master_fd, user_in)
                    # the user interacted: don't fight them on the current prompt
                    answerer.reset()

            now = time.monotonic()
            if pending_check and (now - last_output) >= IDLE_SECS:
                # The screen settled: answer a freshly-appeared prompt.
                pending_check = False
                keys = answerer.on_idle(visible_tail(bytes(raw_buffer)), now)
                if keys is not None:
                    os.write(master_fd, keys)
            elif answerer.retry_pending():
                # No output since we answered: the keystroke may have been
                # dropped mid-redraw. Re-send if the prompt is still up.
                keys = answerer.on_timeout(
                    visible_tail(bytes(raw_buffer)), now,
                    output_since_answer=last_output > answerer.answered_at)
                if keys is not None:
                    os.write(master_fd, keys)
    finally:
        if old_term is not None:
            termios.tcsetattr(stdin_fd, termios.TCSAFLUSH, old_term)
        try:
            os.close(master_fd)
        except OSError:
            pass
        # reap the child and propagate its exit code
        try:
            _, status = os.waitpid(pid, 0)
            if os.WIFEXITED(status):
                exit_code = os.WEXITSTATUS(status)
            elif os.WIFSIGNALED(status):
                exit_code = 128 + os.WTERMSIG(status)
        except OSError:
            pass

    return exit_code


# --------------------------------------------------------------------------
# Windows: ConPTY pseudoconsole, driven through ctypes (no dependencies).
# Mirrors the POSIX path: write the child's output to the real console, keep a
# rolling buffer, and after an idle gap inspect the tail and inject keystrokes.
# Requires Windows 10 1809+ (the first build with the ConPTY API).
# --------------------------------------------------------------------------
if WINDOWS:
    import ctypes
    import shutil
    import threading
    from ctypes import wintypes

    _kernel32 = ctypes.WinDLL("kernel32", use_last_error=True)

    _STD_INPUT_HANDLE = 0xFFFFFFF6   # (DWORD)-10
    _STD_OUTPUT_HANDLE = 0xFFFFFFF5  # (DWORD)-11
    _ENABLE_PROCESSED_INPUT = 0x0001
    _ENABLE_LINE_INPUT = 0x0002
    _ENABLE_ECHO_INPUT = 0x0004
    _ENABLE_VIRTUAL_TERMINAL_INPUT = 0x0200
    _ENABLE_PROCESSED_OUTPUT = 0x0001
    _ENABLE_VIRTUAL_TERMINAL_PROCESSING = 0x0004
    _PROC_THREAD_ATTRIBUTE_PSEUDOCONSOLE = 0x00020016
    _EXTENDED_STARTUPINFO_PRESENT = 0x00080000
    _INFINITE = 0xFFFFFFFF
    _CP_UTF8 = 65001

    class _COORD(ctypes.Structure):
        _fields_ = [("X", wintypes.SHORT), ("Y", wintypes.SHORT)]

    class _SMALL_RECT(ctypes.Structure):
        _fields_ = [("Left", wintypes.SHORT), ("Top", wintypes.SHORT),
                    ("Right", wintypes.SHORT), ("Bottom", wintypes.SHORT)]

    class _CONSOLE_SCREEN_BUFFER_INFO(ctypes.Structure):
        _fields_ = [("dwSize", _COORD), ("dwCursorPosition", _COORD),
                    ("wAttributes", wintypes.WORD), ("srWindow", _SMALL_RECT),
                    ("dwMaximumWindowSize", _COORD)]

    class _STARTUPINFOW(ctypes.Structure):
        _fields_ = [
            ("cb", wintypes.DWORD),
            ("lpReserved", wintypes.LPWSTR),
            ("lpDesktop", wintypes.LPWSTR),
            ("lpTitle", wintypes.LPWSTR),
            ("dwX", wintypes.DWORD),
            ("dwY", wintypes.DWORD),
            ("dwXSize", wintypes.DWORD),
            ("dwYSize", wintypes.DWORD),
            ("dwXCountChars", wintypes.DWORD),
            ("dwYCountChars", wintypes.DWORD),
            ("dwFillAttribute", wintypes.DWORD),
            ("dwFlags", wintypes.DWORD),
            ("wShowWindow", wintypes.WORD),
            ("cbReserved2", wintypes.WORD),
            ("lpReserved2", ctypes.POINTER(ctypes.c_byte)),
            ("hStdInput", wintypes.HANDLE),
            ("hStdOutput", wintypes.HANDLE),
            ("hStdError", wintypes.HANDLE),
        ]

    class _STARTUPINFOEXW(ctypes.Structure):
        _fields_ = [("StartupInfo", _STARTUPINFOW),
                    ("lpAttributeList", ctypes.c_void_p)]

    class _PROCESS_INFORMATION(ctypes.Structure):
        _fields_ = [("hProcess", wintypes.HANDLE), ("hThread", wintypes.HANDLE),
                    ("dwProcessId", wintypes.DWORD), ("dwThreadId", wintypes.DWORD)]

    _kernel32.CreatePipe.argtypes = [
        ctypes.POINTER(wintypes.HANDLE), ctypes.POINTER(wintypes.HANDLE),
        ctypes.c_void_p, wintypes.DWORD]
    _kernel32.CreatePipe.restype = wintypes.BOOL
    _kernel32.ResizePseudoConsole.argtypes = [wintypes.HANDLE, _COORD]
    _kernel32.ResizePseudoConsole.restype = ctypes.c_long
    _kernel32.ClosePseudoConsole.argtypes = [wintypes.HANDLE]
    _kernel32.ClosePseudoConsole.restype = None
    _kernel32.InitializeProcThreadAttributeList.argtypes = [
        ctypes.c_void_p, wintypes.DWORD, wintypes.DWORD,
        ctypes.POINTER(ctypes.c_size_t)]
    _kernel32.InitializeProcThreadAttributeList.restype = wintypes.BOOL
    _kernel32.UpdateProcThreadAttribute.argtypes = [
        ctypes.c_void_p, wintypes.DWORD, ctypes.c_size_t, ctypes.c_void_p,
        ctypes.c_size_t, ctypes.c_void_p, ctypes.POINTER(ctypes.c_size_t)]
    _kernel32.UpdateProcThreadAttribute.restype = wintypes.BOOL
    _kernel32.DeleteProcThreadAttributeList.argtypes = [ctypes.c_void_p]
    _kernel32.DeleteProcThreadAttributeList.restype = None
    _kernel32.CreateProcessW.argtypes = [
        wintypes.LPCWSTR, wintypes.LPWSTR, ctypes.c_void_p, ctypes.c_void_p,
        wintypes.BOOL, wintypes.DWORD, ctypes.c_void_p, wintypes.LPCWSTR,
        ctypes.c_void_p, ctypes.c_void_p]
    _kernel32.CreateProcessW.restype = wintypes.BOOL
    _kernel32.ReadFile.argtypes = [
        wintypes.HANDLE, ctypes.c_void_p, wintypes.DWORD,
        ctypes.POINTER(wintypes.DWORD), ctypes.c_void_p]
    _kernel32.ReadFile.restype = wintypes.BOOL
    _kernel32.WriteFile.argtypes = [
        wintypes.HANDLE, ctypes.c_void_p, wintypes.DWORD,
        ctypes.POINTER(wintypes.DWORD), ctypes.c_void_p]
    _kernel32.WriteFile.restype = wintypes.BOOL
    _kernel32.CloseHandle.argtypes = [wintypes.HANDLE]
    _kernel32.CloseHandle.restype = wintypes.BOOL
    _kernel32.GetStdHandle.argtypes = [wintypes.DWORD]
    _kernel32.GetStdHandle.restype = wintypes.HANDLE
    _kernel32.GetConsoleMode.argtypes = [
        wintypes.HANDLE, ctypes.POINTER(wintypes.DWORD)]
    _kernel32.GetConsoleMode.restype = wintypes.BOOL
    _kernel32.SetConsoleMode.argtypes = [wintypes.HANDLE, wintypes.DWORD]
    _kernel32.SetConsoleMode.restype = wintypes.BOOL
    _kernel32.GetConsoleScreenBufferInfo.argtypes = [
        wintypes.HANDLE, ctypes.POINTER(_CONSOLE_SCREEN_BUFFER_INFO)]
    _kernel32.GetConsoleScreenBufferInfo.restype = wintypes.BOOL
    _kernel32.GetConsoleOutputCP.restype = wintypes.UINT
    _kernel32.GetConsoleCP.restype = wintypes.UINT
    _kernel32.SetConsoleOutputCP.argtypes = [wintypes.UINT]
    _kernel32.SetConsoleOutputCP.restype = wintypes.BOOL
    _kernel32.SetConsoleCP.argtypes = [wintypes.UINT]
    _kernel32.SetConsoleCP.restype = wintypes.BOOL
    _kernel32.WaitForSingleObject.argtypes = [wintypes.HANDLE, wintypes.DWORD]
    _kernel32.WaitForSingleObject.restype = wintypes.DWORD
    _kernel32.GetExitCodeProcess.argtypes = [
        wintypes.HANDLE, ctypes.POINTER(wintypes.DWORD)]
    _kernel32.GetExitCodeProcess.restype = wintypes.BOOL
    # CreatePseudoConsole takes a COORD by value; it is absent on pre-1809
    # Windows, so resolve it defensively.
    _create_pseudo_console = getattr(_kernel32, "CreatePseudoConsole", None)
    if _create_pseudo_console is not None:
        _create_pseudo_console.argtypes = [
            _COORD, wintypes.HANDLE, wintypes.HANDLE, wintypes.DWORD,
            ctypes.POINTER(wintypes.HANDLE)]
        _create_pseudo_console.restype = ctypes.c_long  # HRESULT

    def _win_winsize(stdout_h):
        """Return the (rows, cols) of the console window, defaulting to (24, 80)."""
        info = _CONSOLE_SCREEN_BUFFER_INFO()
        if _kernel32.GetConsoleScreenBufferInfo(stdout_h, ctypes.byref(info)):
            cols = info.srWindow.Right - info.srWindow.Left + 1
            rows = info.srWindow.Bottom - info.srWindow.Top + 1
            if cols > 0 and rows > 0:
                return rows, cols
        return 24, 80

    def _win_command_line(tool):
        """Resolve `tool` on PATH and build a CreateProcessW command line.

        CreateProcess does not honour PATHEXT or run .cmd/.bat shims directly
        (npm installs `claude` as a .cmd shim), so resolve with shutil.which
        and route batch shims through cmd.exe.
        """
        exe = shutil.which(tool)
        if exe is None:
            return None
        if exe.lower().endswith((".cmd", ".bat")):
            return f'cmd.exe /c "{exe}"'
        return f'"{exe}"'

    def _run_windows(tool, patterns):
        """Run `tool` under a ConPTY, auto-answering prompts. Returns an exit code."""
        if _create_pseudo_console is None:
            sys.stderr.write(
                "auto: this Windows build lacks ConPTY (needs Windows 10 1809+).\n"
            )
            return 1

        cmdline = _win_command_line(tool)
        if cmdline is None:
            sys.stderr.write(f"auto: could not run {tool!r}: not found on PATH\n")
            return 127

        stdin_h = _kernel32.GetStdHandle(_STD_INPUT_HANDLE)
        stdout_h = _kernel32.GetStdHandle(_STD_OUTPUT_HANDLE)
        rows, cols = _win_winsize(stdout_h)

        # Two pipes: one feeds keystrokes into the PTY, one carries its output.
        pty_in_read = wintypes.HANDLE()
        our_in_write = wintypes.HANDLE()
        our_out_read = wintypes.HANDLE()
        pty_out_write = wintypes.HANDLE()
        if not _kernel32.CreatePipe(
                ctypes.byref(pty_in_read), ctypes.byref(our_in_write), None, 0):
            raise ctypes.WinError(ctypes.get_last_error())
        if not _kernel32.CreatePipe(
                ctypes.byref(our_out_read), ctypes.byref(pty_out_write), None, 0):
            raise ctypes.WinError(ctypes.get_last_error())

        hpc = wintypes.HANDLE()
        hr = _create_pseudo_console(
            _COORD(cols, rows), pty_in_read, pty_out_write, 0, ctypes.byref(hpc))
        if hr != 0:
            raise OSError(f"CreatePseudoConsole failed (HRESULT 0x{hr & 0xFFFFFFFF:08x})")
        # ConPTY duplicated the PTY-side handles; closing our copies lets the
        # output read return EOF once the child exits.
        _kernel32.CloseHandle(pty_in_read)
        _kernel32.CloseHandle(pty_out_write)

        # Attach the pseudoconsole to the child via a process attribute list.
        attr_size = ctypes.c_size_t(0)
        _kernel32.InitializeProcThreadAttributeList(
            None, 1, 0, ctypes.byref(attr_size))
        attr_buf = (ctypes.c_byte * attr_size.value)()
        attr_list = ctypes.cast(attr_buf, ctypes.c_void_p)
        if not _kernel32.InitializeProcThreadAttributeList(
                attr_list, 1, 0, ctypes.byref(attr_size)):
            raise ctypes.WinError(ctypes.get_last_error())
        if not _kernel32.UpdateProcThreadAttribute(
                attr_list, 0, _PROC_THREAD_ATTRIBUTE_PSEUDOCONSOLE,
                hpc, ctypes.sizeof(wintypes.HANDLE), None, None):
            raise ctypes.WinError(ctypes.get_last_error())

        siex = _STARTUPINFOEXW()
        siex.StartupInfo.cb = ctypes.sizeof(_STARTUPINFOEXW)
        siex.lpAttributeList = attr_list
        pi = _PROCESS_INFORMATION()
        cmd_buf = ctypes.create_unicode_buffer(cmdline)
        if not _kernel32.CreateProcessW(
                None, cmd_buf, None, None, False, _EXTENDED_STARTUPINFO_PRESENT,
                None, None, ctypes.byref(siex), ctypes.byref(pi)):
            err = ctypes.get_last_error()
            _kernel32.ClosePseudoConsole(hpc)
            _kernel32.DeleteProcThreadAttributeList(attr_list)
            _kernel32.CloseHandle(our_out_read)
            _kernel32.CloseHandle(our_in_write)
            sys.stderr.write(
                f"auto: could not run {tool!r}: {ctypes.WinError(err)}\n")
            return 127

        # Put the real console into raw, VT-aware, UTF-8 mode so keystrokes are
        # forwarded byte-for-byte and the child's VT output renders correctly.
        old_in_mode = wintypes.DWORD()
        old_out_mode = wintypes.DWORD()
        have_in = bool(_kernel32.GetConsoleMode(stdin_h, ctypes.byref(old_in_mode)))
        have_out = bool(_kernel32.GetConsoleMode(stdout_h, ctypes.byref(old_out_mode)))
        old_out_cp = _kernel32.GetConsoleOutputCP()
        old_in_cp = _kernel32.GetConsoleCP()
        if have_in:
            new_in = (old_in_mode.value
                      & ~_ENABLE_LINE_INPUT
                      & ~_ENABLE_ECHO_INPUT
                      & ~_ENABLE_PROCESSED_INPUT) | _ENABLE_VIRTUAL_TERMINAL_INPUT
            _kernel32.SetConsoleMode(stdin_h, new_in)
        if have_out:
            _kernel32.SetConsoleMode(
                stdout_h, old_out_mode.value
                | _ENABLE_PROCESSED_OUTPUT | _ENABLE_VIRTUAL_TERMINAL_PROCESSING)
        _kernel32.SetConsoleOutputCP(_CP_UTF8)
        _kernel32.SetConsoleCP(_CP_UTF8)

        lock = threading.Lock()
        done = threading.Event()
        state = {"buffer": bytearray(), "last_output": time.monotonic(),
                 "pending": False, "user_typed": False}
        answerer = Answerer(patterns)

        def _pump_output():
            buf = (ctypes.c_char * 4096)()
            nread = wintypes.DWORD(0)
            wn = wintypes.DWORD(0)
            while True:
                ok = _kernel32.ReadFile(
                    our_out_read, buf, 4096, ctypes.byref(nread), None)
                if not ok or nread.value == 0:
                    break  # PTY closed its output -> the child exited
                data = bytes(buf[:nread.value])
                _kernel32.WriteFile(stdout_h, data, len(data), ctypes.byref(wn), None)
                with lock:
                    state["buffer"].extend(data)
                    if len(state["buffer"]) > BUFFER_LIMIT:
                        del state["buffer"][:-BUFFER_LIMIT]
                    state["last_output"] = time.monotonic()
                    state["pending"] = True
            done.set()

        def _pump_input():
            buf = (ctypes.c_char * 4096)()
            nread = wintypes.DWORD(0)
            wn = wintypes.DWORD(0)
            while not done.is_set():
                ok = _kernel32.ReadFile(
                    stdin_h, buf, 4096, ctypes.byref(nread), None)
                if not ok or nread.value == 0:
                    break
                data = bytes(buf[:nread.value])
                _kernel32.WriteFile(
                    our_in_write, data, len(data), ctypes.byref(wn), None)
                # the user interacted: don't fight them on the current prompt
                with lock:
                    state["user_typed"] = True

        threading.Thread(target=_pump_output, daemon=True).start()
        threading.Thread(target=_pump_input, daemon=True).start()

        last_size = (rows, cols)
        exit_code = 0
        wn = wintypes.DWORD(0)
        try:
            while not done.is_set():
                done.wait(0.05)
                now = time.monotonic()
                tail = None
                idle = False
                out_since = False
                with lock:
                    user_typed = state["user_typed"]
                    state["user_typed"] = False
                    idle = (state["pending"]
                            and (now - state["last_output"]) >= IDLE_SECS)
                    if idle:
                        state["pending"] = False
                    if idle or answerer.retry_pending():
                        tail = visible_tail(bytes(state["buffer"]))
                        out_since = state["last_output"] > answerer.answered_at
                if user_typed:
                    answerer.reset()
                keys = None
                if idle and tail is not None:
                    # The screen settled: answer a freshly-appeared prompt.
                    keys = answerer.on_idle(tail, now)
                elif tail is not None and answerer.retry_pending():
                    # No output since we answered: re-send if still on screen.
                    keys = answerer.on_timeout(
                        tail, now, output_since_answer=out_since)
                if keys is not None:
                    _kernel32.WriteFile(
                        our_in_write, keys, len(keys), ctypes.byref(wn), None)
                # propagate console resizes (Windows has no SIGWINCH)
                r, c = _win_winsize(stdout_h)
                if (r, c) != last_size:
                    last_size = (r, c)
                    _kernel32.ResizePseudoConsole(hpc, _COORD(c, r))
        finally:
            _kernel32.WaitForSingleObject(pi.hProcess, _INFINITE)
            code = wintypes.DWORD(0)
            if _kernel32.GetExitCodeProcess(pi.hProcess, ctypes.byref(code)):
                exit_code = code.value
            _kernel32.ClosePseudoConsole(hpc)
            _kernel32.DeleteProcThreadAttributeList(attr_list)
            _kernel32.CloseHandle(our_out_read)
            _kernel32.CloseHandle(our_in_write)
            _kernel32.CloseHandle(pi.hThread)
            _kernel32.CloseHandle(pi.hProcess)
            if have_in:
                _kernel32.SetConsoleMode(stdin_h, old_in_mode.value)
            if have_out:
                _kernel32.SetConsoleMode(stdout_h, old_out_mode.value)
            _kernel32.SetConsoleOutputCP(old_out_cp)
            _kernel32.SetConsoleCP(old_in_cp)

        return exit_code


def main(argv=None):
    if argv is None:
        argv = sys.argv
    tool = resolve_tool(argv)
    if tool in ("--version", "-V", "version"):
        sys.stdout.write(f"auto {__version__}\n")
        sys.exit(0)
    if tool == "update":
        sys.exit(update())
    if tool not in TOOLS:
        sys.stderr.write(
            f"auto: tool {tool!r} is not supported. "
            f"Use: {' or '.join(sorted(TOOLS))} (or 'update').\n"
        )
        sys.exit(2)

    # Announce the running version before handing the terminal to the tool.
    sys.stderr.write(f"auto {__version__}\n")
    patterns = compile_patterns(tool)
    if WINDOWS:
        sys.exit(_run_windows(tool, patterns))
    sys.exit(_run_posix(tool, patterns))


if __name__ == "__main__":
    main()
