#!/usr/bin/env python3
"""
auto — runs `claude` or `codex` inside a pseudo-terminal (PTY) and
automatically answers "yes" every time the tool pauses to ask for
confirmation.

Usage:
    auto claude
    auto codex
    auto            # default: claude
    auto update     # self-update via `git pull` in the install directory

Apart from the `update` subcommand, there are no other options and no
alternative command: it just launches the chosen tool and auto-accepts the
confirmation prompts.

Platforms: Linux and macOS use a POSIX PTY (`pty.fork`). Windows uses a
ConPTY pseudoconsole driven through `ctypes` (no third-party dependency;
requires Windows 10 1809+). The prompt-detection logic is shared.

SECURITY WARNING: auto-accepting EVERYTHING also bypasses confirmations for
destructive actions. Prefer running it inside a throwaway directory. See
README.md.
"""

import errno
import os
import re
import subprocess
import sys
import time

POSIX = os.name == "posix"
WINDOWS = os.name == "nt"

if POSIX:
    import fcntl
    import pty
    import select
    import signal
    import struct
    import termios
    import tty

__version__ = "0.1.8"

ENTER = b"\r"

# Supported tools. Each one: a list of (prompt regex, key(s) to send).
# The first rule that matches the visible "tail" of the screen wins.
#
# The leading `[ \t│|]*` tolerates a box border before the arrow/number:
# claude (and others) draw their confirmation menus inside a `│ … │` box, so
# the menu line reads `│ ❯ 1. Yes` rather than starting with the arrow itself.
# Without this, the generic fallback never matches a boxed menu and `auto`
# hangs whenever the question text isn't covered by a tool-specific rule.
YES_MENU_PATTERNS = [
    (r"(?m)^[ \t│|]*[❯›➜→>]\s*(?:\d+[.)]\s*)?Yes\b", ENTER),
    (r"(?m)^[ \t│|]*1[.)]\s*Yes\b[\s\S]*\b2[.)]\s*(?:No|Cancel)\b", ENTER),
]

TOOLS = {
    "claude": [
        (r"Do you want to (proceed|make this edit|create|run)", ENTER),
        *YES_MENU_PATTERNS,
    ],
    "codex": [
        (r"Allow.*\?", ENTER),
        (r"Would you like to run the following command\?", ENTER),
        (r"Approve", ENTER),
        *YES_MENU_PATTERNS,
        (r"[\[(]\s*y\s*/\s*n\s*[\])]", b"y\r"),
    ],
}

# Regex that strips ANSI escape sequences (colors, cursor positioning, etc.).
ANSI_RE = re.compile(r"\x1b\[[0-9;?]*[ -/]*[@-~]|\x1b[\(\)][AB012]|\x1b[=>]|\r")

# A full redraw of a colored TUI screen is easily 10-20 KB of ANSI, and a tall
# confirmation (a long, multi-line command in the box) is larger still. The cap
# must comfortably hold one such screen plus the footer/spinner frames the tool
# keeps appending while the prompt sits there -- otherwise the question scrolls
# out of the retained window and the prompt is never answered.
BUFFER_LIMIT = 65536         # raw bytes kept for detection
# Enough lines to reach back past the tool's footer (input box, hints, status,
# spinner) to the question line of a tall prompt, without dredging up stale
# scrollback from earlier in the conversation.
TAIL_LINES = 40              # how many visible lines to inspect when matching
# How long a prompt must stay continuously on screen before we answer it. This
# is a stability window, NOT a whole-screen idle gate: the tool often keeps
# repainting an animated element (a spinner, an elapsed-time counter, an "esc
# to interrupt" hint) the entire time a confirmation is displayed, so the screen
# never goes quiet. We key on the *matched prompt text*, which holds still while
# that noise churns, and answer once it has held for this long.
IDLE_SECS = 0.4
# While a prompt is being tracked, re-inspect the screen this often so the
# stability window and re-sends fire even when the tool has gone silent.
POLL_SECS = 0.1
# If a prompt we already answered is still on screen this long after, the
# keystroke was almost certainly dropped while the TUI was redrawing -- re-send
# the answer instead of waiting forever.
ANSWER_RETRY_SECS = 1.5
# Bounded re-sends, so a genuinely stuck prompt does not turn into an endless
# stream of keystrokes injected into the tool.
MAX_ANSWER_RETRIES = 2


def resolve_tool(argv):
    """Return the tool name from argv (defaults to "claude").

    argv is expected to look like sys.argv: argv[0] is the program name and
    argv[1], if present, is the tool to run.
    """
    return argv[1] if len(argv) > 1 else "claude"


def compile_patterns(tool):
    """Compile the prompt patterns for a tool into (regex, keys) pairs.

    Raises KeyError if the tool is unknown.
    """
    return [(re.compile(rx, re.IGNORECASE), keys) for rx, keys in TOOLS[tool]]


def strip_ansi(text):
    """Remove ANSI escape sequences and carriage returns from text."""
    return ANSI_RE.sub("", text)


def visible_tail(raw_buffer, tail_lines=TAIL_LINES):
    """Strip ANSI codes and return the last `tail_lines` lines as one string."""
    text = strip_ansi(raw_buffer.decode("utf-8", errors="replace"))
    lines = text.split("\n")
    return "\n".join(lines[-tail_lines:])


def match_prompt_ex(tail, patterns):
    """Return (keys, matched_text) for the first matching pattern, else None.

    `matched_text` is the exact substring the pattern matched -- the menu line
    or question, but not the surrounding spinner / timer noise. It serves as a
    stable identity for the prompt so we can tell "the same prompt, still up" (a
    repaint) apart from "a different prompt" even while the rest of the screen
    keeps churning.

    `patterns` is a list of (compiled_regex, keys) pairs, as produced by
    compile_patterns.
    """
    for rx, keys in patterns:
        m = rx.search(tail)
        if m:
            return keys, m.group(0)
    return None


def match_prompt(tail, patterns):
    """Return the key(s) to send for the first matching pattern, else None.

    `patterns` is a list of (compiled_regex, keys) pairs, as produced by
    compile_patterns.
    """
    match = match_prompt_ex(tail, patterns)
    return match[0] if match is not None else None


def append_debug(path, now, tail, match):
    """Append one diagnostic record (the visible tail + match result) to `path`.

    Opt-in via the `AUTO_DEBUG` env var. When a prompt is missed, the regexes
    almost always match the clean text, so the real cause hides in what the PTY
    actually delivered -- a tail garbled by escape sequences or a partial
    redraw. Dumping the exact tail and whether it matched is what turns "auto
    didn't catch it" into a reproducible, fixable record. Never raises into the
    event loop: a debug sink that fails must not take the wrapper down with it.
    """
    try:
        sig = match[1] if match is not None else None
        verdict = f"MATCH {sig!r}" if match is not None else "NO MATCH"
        with open(path, "a", encoding="utf-8") as f:
            f.write(f"\n----- t={now:.3f} {verdict} -----\n")
            f.write(tail)
            f.write("\n")
    except OSError:
        pass


class Answerer:
    """Decides what (if anything) to send to an auto-answered tool.

    This is the shared, side-effect-free brain used by both the POSIX and the
    Windows event loops. Drive it by calling `consider(tail, now)` on every
    loop tick (after each chunk of output and, while a prompt is up, on a short
    poll). It keeps just enough state to:

    * answer a prompt once it has stayed on screen for `stable_secs`, even while
      the tool keeps repainting an animated element (a spinner, an elapsed-time
      counter, an "esc to interrupt" hint) so the screen never goes quiet -- the
      dedup key is the *matched prompt text*, which holds still through that
      churn, not the whole screen;
    * answer it exactly once, and
    * re-send the answer a bounded number of times if it never took effect.

    The last point covers a keystroke the TUI drops while repainting, which used
    to leave `auto` blocked forever; if the same prompt is still on screen a
    while after we answered, we send it again.
    """

    def __init__(self, patterns, stable_secs=IDLE_SECS,
                 retry_secs=ANSWER_RETRY_SECS, max_retries=MAX_ANSWER_RETRIES,
                 debug_path=None):
        self.patterns = patterns
        self.stable_secs = stable_secs
        self.retry_secs = retry_secs
        self.max_retries = max_retries
        # Optional diagnostic sink (the AUTO_DEBUG path). When set, each changed
        # screen is recorded with its match verdict so a missed prompt can be
        # inspected after the fact. `_last_logged` dedups identical tails.
        self.debug_path = debug_path
        self._last_logged = None
        self.reset()

    def reset(self):
        """Forget the tracked prompt; call when the user takes over a prompt."""
        self.sig = None           # matched text of the prompt currently up
        self.keys = None          # keys that answer it
        self.seen_at = 0.0        # when this prompt first appeared (monotonic)
        self.answered = False     # have we sent its answer yet?
        self.answered_at = 0.0    # when we last sent it (for re-sends)
        self.retries = 0          # re-sends issued for this prompt

    def needs_tick(self):
        """Whether the loop should keep polling (vs. block until more output).

        True while a prompt is tracked and there is still work to do for it:
        the stability window has not elapsed, or a re-send may still be due.
        """
        if self.sig is None:
            return False
        return not self.answered or self.retries < self.max_retries

    def consider(self, tail, now):
        """Inspect the current screen; return keys to send, or None.

        Tracks the prompt by its matched text. A freshly-appeared prompt is
        answered once it has held for `stable_secs`; an already-answered prompt
        that lingers is re-sent up to `max_retries` times.
        """
        match = match_prompt_ex(tail, self.patterns)
        if self.debug_path and tail != self._last_logged:
            self._last_logged = tail
            append_debug(self.debug_path, now, tail, match)
        if match is None:
            self.reset()                       # no prompt on screen anymore
            return None
        keys, sig = match
        if sig != self.sig:
            # A new (or changed) prompt: start its stability window afresh.
            self.sig = sig
            self.keys = keys
            self.seen_at = now
            self.answered = False
            self.retries = 0
            return None
        if not self.answered:
            if (now - self.seen_at) < self.stable_secs:
                return None                    # not stable long enough yet
            self.answered = True
            self.answered_at = now
            return keys
        # Already answered. If it is still up well after we answered, the
        # keystroke was likely dropped mid-redraw -- re-send, bounded.
        if self.retries >= self.max_retries:
            return None
        if (now - self.answered_at) < self.retry_secs:
            return None
        self.retries += 1
        self.answered_at = now
        return keys


def install_dir(path=None):
    """Return the directory of the real `auto` script, resolving symlinks.

    `auto` is typically installed as a symlink on the PATH pointing at a git
    checkout, so the actual repository lives at the symlink's target.
    """
    return os.path.dirname(os.path.realpath(path or __file__))


def update(repo=None, runner=subprocess.call):
    """Self-update the install with `git pull --ff-only`. Return an exit code.

    `repo` defaults to the install directory; `runner` runs the git command
    (injectable for testing). Returns 1 if `repo` is not a git checkout,
    otherwise the exit code reported by git.
    """
    repo = repo if repo is not None else install_dir()
    if not os.path.isdir(os.path.join(repo, ".git")):
        sys.stderr.write(
            f"auto: {repo!r} is not a git checkout; cannot self-update.\n"
        )
        return 1
    return runner(["git", "-C", repo, "pull", "--ff-only"])


# Matches the `__version__ = "X.Y.Z"` assignment so the version can be bumped
# in place (used by the pre-commit hook) without touching the rest of the file.
VERSION_RE = re.compile(r'(?m)^__version__\s*=\s*"(?P<v>\d+\.\d+\.\d+)"')


def bump_version(version, part="patch"):
    """Return `version` (a "MAJOR.MINOR.PATCH" string) with `part` incremented.

    Bumping major resets minor and patch to 0; bumping minor resets patch.
    """
    major, minor, patch = (int(n) for n in version.split("."))
    if part == "major":
        return f"{major + 1}.0.0"
    if part == "minor":
        return f"{major}.{minor + 1}.0"
    if part == "patch":
        return f"{major}.{minor}.{patch + 1}"
    raise ValueError(f"unknown version part: {part!r}")


def bump_source(path=None, part="patch"):
    """Increment the `__version__` string inside the `auto` source file.

    `path` defaults to this script. Returns the new version. Raises ValueError
    if no `__version__` assignment is found.
    """
    path = path if path is not None else os.path.realpath(__file__)
    with open(path, encoding="utf-8") as f:
        text = f.read()
    match = VERSION_RE.search(text)
    if match is None:
        raise ValueError(f"no __version__ string found in {path!r}")
    new_version = bump_version(match.group("v"), part)
    new_text = text[: match.start("v")] + new_version + text[match.end("v") :]
    with open(path, "w", encoding="utf-8") as f:
        f.write(new_text)
    return new_version


def get_winsize(fd):
    """Return the (rows, cols) window size of fd, defaulting to (24, 80)."""
    try:
        data = fcntl.ioctl(fd, termios.TIOCGWINSZ, b"\x00" * 8)
        rows, cols, _, _ = struct.unpack("HHHH", data)
        return rows, cols
    except OSError:
        return 24, 80


def set_winsize(fd, rows, cols):
    """Set the window size of fd to (rows, cols), ignoring errors."""
    try:
        fcntl.ioctl(fd, termios.TIOCSWINSZ, struct.pack("HHHH", rows, cols, 0, 0))
    except OSError:
        pass


def _run_posix(tool, patterns):
    """Run `tool` under a POSIX PTY, auto-answering prompts. Returns an exit code."""
    target = [tool]

    stdin_fd = sys.stdin.fileno()
    stdout_fd = sys.stdout.fileno()

    rows, cols = get_winsize(stdin_fd)

    pid, master_fd = pty.fork()
    if pid == 0:
        # ---- child process ----
        try:
            os.execvp(target[0], target)
        except OSError as e:
            sys.stderr.write(f"auto: could not run {target[0]!r}: {e}\n")
            os._exit(127)

    # ---- parent process ----
    set_winsize(master_fd, rows, cols)

    def handle_winch(signum, frame):
        r, c = get_winsize(stdin_fd)
        set_winsize(master_fd, r, c)

    signal.signal(signal.SIGWINCH, handle_winch)

    old_term = None
    if os.isatty(stdin_fd):
        old_term = termios.tcgetattr(stdin_fd)
        tty.setraw(stdin_fd)

    raw_buffer = bytearray()
    # decides what to send (and when to re-send); AUTO_DEBUG records what it sees
    answerer = Answerer(patterns, debug_path=os.environ.get("AUTO_DEBUG"))
    exit_code = 0

    try:
        while True:
            # Block on IO normally, but while a prompt is being tracked poll on
            # a short tick so its stability window and re-sends advance even if
            # the tool has stopped drawing (a settled, static prompt).
            timeout = POLL_SECS if answerer.needs_tick() else None
            try:
                rlist, _, _ = select.select([stdin_fd, master_fd], [], [], timeout)
            except select.error as e:
                if e.args[0] == errno.EINTR:
                    continue  # interrupted by SIGWINCH; resume
                raise

            if master_fd in rlist:
                try:
                    data = os.read(master_fd, 4096)
                except OSError:
                    data = b""
                if not data:
                    break  # child closed the PTY -> it exited
                os.write(stdout_fd, data)
                raw_buffer.extend(data)
                if len(raw_buffer) > BUFFER_LIMIT:
                    del raw_buffer[:-BUFFER_LIMIT]

            if stdin_fd in rlist:
                try:
                    user_in = os.read(stdin_fd, 4096)
                except OSError:
                    user_in = b""
                if user_in:
                    os.write(master_fd, user_in)
                    # the user interacted: don't fight them on the current prompt
                    answerer.reset()
                    continue

            # Inspect the screen every tick. The answerer keys on the matched
            # prompt text, so it answers a prompt that has held still long
            # enough even while a spinner keeps the rest of the screen churning.
            keys = answerer.consider(visible_tail(bytes(raw_buffer)),
                                     time.monotonic())
            if keys is not None:
                os.write(master_fd, keys)
    finally:
        if old_term is not None:
            termios.tcsetattr(stdin_fd, termios.TCSAFLUSH, old_term)
        try:
            os.close(master_fd)
        except OSError:
            pass
        # reap the child and propagate its exit code
        try:
            _, status = os.waitpid(pid, 0)
            if os.WIFEXITED(status):
                exit_code = os.WEXITSTATUS(status)
            elif os.WIFSIGNALED(status):
                exit_code = 128 + os.WTERMSIG(status)
        except OSError:
            pass

    return exit_code


