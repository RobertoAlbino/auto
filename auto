#!/usr/bin/env python3
"""
auto — runs `claude` or `codex` inside a pseudo-terminal (PTY) and
automatically answers "yes" every time the tool pauses to ask for
confirmation.

Usage:
    auto claude
    auto codex
    auto            # default: claude
    auto update     # self-update via `git pull` in the install directory

Apart from the `update` subcommand, there are no other options and no
alternative command: it just launches the chosen tool and auto-accepts the
confirmation prompts.

Platforms: Linux and macOS use a POSIX PTY (`pty.fork`). Windows uses a
ConPTY pseudoconsole driven through `ctypes` (no third-party dependency;
requires Windows 10 1809+). The prompt-detection logic is shared: the PTY
stream feeds a small terminal-screen emulator, and the patterns are matched
against what is actually visible on screen.

SECURITY WARNING: auto-accepting EVERYTHING also bypasses confirmations for
destructive actions. Prefer running it inside a throwaway directory. See
README.md.
"""

import codecs
import errno
import os
import re
import subprocess
import sys
import time

POSIX = os.name == "posix"
WINDOWS = os.name == "nt"

if POSIX:
    import fcntl
    import pty
    import select
    import signal
    import struct
    import termios
    import tty

__version__ = "0.1.9"

ENTER = b"\r"

# Supported tools. Each one: a list of (prompt regex, key(s) to send).
# The first rule that matches the visible "tail" of the screen wins.
#
# The leading `[ \t│|]*` tolerates a box border before the arrow/number:
# claude (and others) draw their confirmation menus inside a `│ … │` box, so
# the menu line reads `│ ❯ 1. Yes` rather than starting with the arrow itself.
# Without this, the generic fallback never matches a boxed menu and `auto`
# hangs whenever the question text isn't covered by a tool-specific rule.
YES_MENU_PATTERNS = [
    (r"(?m)^[ \t│|]*[❯›➜→>]\s*(?:\d+[.)]\s*)?Yes\b", ENTER),
    (r"(?m)^[ \t│|]*1[.)]\s*Yes\b[\s\S]*\b2[.)]\s*(?:No|Cancel)\b", ENTER),
]

TOOLS = {
    "claude": [
        (r"Do you want to (proceed|make this edit|create|run)", ENTER),
        *YES_MENU_PATTERNS,
    ],
    "codex": [
        (r"Allow.*\?", ENTER),
        (r"Would you like to run the following command\?", ENTER),
        (r"Approve", ENTER),
        *YES_MENU_PATTERNS,
        (r"[\[(]\s*y\s*/\s*n\s*[\])]", b"y\r"),
    ],
}

# How long a prompt must stay continuously on screen before we answer it. This
# is a stability window, NOT a whole-screen idle gate: the tool often keeps
# repainting an animated element (a spinner, an elapsed-time counter, an "esc
# to interrupt" hint) the entire time a confirmation is displayed, so the screen
# never goes quiet. We key on the *matched prompt text*, which holds still while
# that noise churns, and answer once it has held for this long.
IDLE_SECS = 0.4
# While a prompt is being tracked, re-inspect the screen this often so the
# stability window and re-sends fire even when the tool has gone silent.
POLL_SECS = 0.1
# If a prompt we already answered is still on screen this long after, the
# keystroke was almost certainly dropped while the TUI was redrawing -- re-send
# the answer instead of waiting forever.
ANSWER_RETRY_SECS = 1.5
# Bounded re-sends, so a genuinely stuck prompt does not turn into an endless
# stream of keystrokes injected into the tool.
MAX_ANSWER_RETRIES = 2


def resolve_tool(argv):
    """Return the tool name from argv (defaults to "claude").

    argv is expected to look like sys.argv: argv[0] is the program name and
    argv[1], if present, is the tool to run.
    """
    return argv[1] if len(argv) > 1 else "claude"


def compile_patterns(tool):
    """Compile the prompt patterns for a tool into (regex, keys) pairs.

    Raises KeyError if the tool is unknown.
    """
    return [(re.compile(rx, re.IGNORECASE), keys) for rx, keys in TOOLS[tool]]


# --------------------------------------------------------------------------
# Screen model.
#
# Detection used to run on the tail of the raw byte stream with the ANSI
# escapes stripped out. That representation cannot answer the one question
# that matters -- "is the prompt visible right now?" -- because a byte stream
# is append-only: a dialog the tool has already erased keeps matching until
# enough newlines arrive to push its text out of the tail. The visible
# symptom was a missed "yes": when two identical confirmations arrived close
# together, the second was indistinguishable from the stale text of the first
# (same matched text, already answered) and was never answered. The converse
# also happened -- answers re-sent at text that was no longer on screen.
#
# So interpret the escape sequences instead of stripping them: keep the grid
# of characters a real terminal would show. Erased text actually disappears,
# a still-up dialog actually persists, and matching the screen means matching
# what the user can see. Only the control sequences the wrapped TUIs emit
# (cursor motion, erasing, scrolling, the alternate screen) need to be
# honoured; colors/styles are ignored.
# --------------------------------------------------------------------------

# One terminal "token": a complete escape sequence or a single C0 control.
_TOKEN_RE = re.compile(
    "\x1b\\[[0-9;:?>=!<]*[ -/]*[@-~]"          # CSI ... final byte
    "|\x1b\\][^\x07\x1b]*(?:\x07|\x1b\\\\)?"   # OSC (window title etc.)
    "|\x1b[P^_X][^\x1b]*(?:\x1b\\\\)?"         # DCS / PM / APC / SOS
    "|\x1b[()*+#%]."                           # charset & line-size selectors
    "|\x1b."                                   # any other two-char escape
    "|[\x00-\x1a\x1c-\x1f\x7f]"                # C0 controls except ESC
)

# A trailing fragment that is the *start* of an escape sequence whose end has
# not arrived yet: PTY reads are arbitrary 4 KB chunks, so sequences split.
_PARTIAL_RE = re.compile(
    "\x1b\\[[0-9;:?>=!<]*[ -/]*"   # CSI missing its final byte
    "|\x1b\\][^\x07\x1b]*"         # OSC missing its terminator
    "|\x1b[P^_X][^\x1b]*"          # DCS/PM/APC missing its terminator
    "|\x1b[()*+#%]"                # charset selector missing its charset
    "|\x1b"                        # bare escape
)


class Screen:
    """What the terminal currently shows, reconstructed from the PTY stream.

    feed() bytes as they arrive; text() returns the visible grid, one string
    per row joined with newlines (trailing blanks stripped). Handles the
    sequences claude/codex actually emit: absolute and relative cursor
    motion, line/display erasing, scrolling (with regions), insert/delete of
    lines and characters, the alternate screen, and save/restore cursor.
    Styling and anything unrecognized are ignored.
    """

    _PENDING_MAX = 8192  # give up on an unterminated OSC/DCS at this size

    def __init__(self, rows=24, cols=80):
        self.rows = max(1, rows)
        self.cols = max(1, cols)
        self._decoder = codecs.getincrementaldecoder("utf-8")("replace")
        self._pending = ""             # escape sequence split across feeds
        self._main = self._blank_grid()
        self._alt = self._blank_grid()
        self._grid = self._main
        self._on_alt = False
        self.row = 0
        self.col = 0
        self._saved = (0, 0)
        self._top = 0                  # scroll region, inclusive
        self._bot = self.rows - 1

    def _blank_row(self):
        return [" "] * self.cols

    def _blank_grid(self):
        return [self._blank_row() for _ in range(self.rows)]

    def _clamped(self, row, col):
        return (min(max(row, 0), self.rows - 1),
                min(max(col, 0), self.cols - 1))

    def text(self):
        """The visible screen as one string, one line per row."""
        return "\n".join("".join(line).rstrip() for line in self._grid)

    def resize(self, rows, cols):
        """Match a terminal resize, preserving the top-left of the content."""
        rows, cols = max(1, rows), max(1, cols)
        for grid in (self._main, self._alt):
            for line in grid:
                if cols > len(line):
                    line.extend(" " * (cols - len(line)))
                else:
                    del line[cols:]
            while len(grid) < rows:
                grid.append([" "] * cols)
            del grid[rows:]
        self.rows, self.cols = rows, cols
        self._top, self._bot = 0, rows - 1
        self.row, self.col = self._clamped(self.row, self.col)

    def feed(self, data):
        """Interpret a chunk of PTY output and update the grid."""
        text = self._pending + self._decoder.decode(data)
        self._pending = ""
        # Hold back a trailing incomplete escape sequence for the next chunk.
        cut = text.rfind("\x1b")
        if (cut != -1 and len(text) - cut <= self._PENDING_MAX
                and _PARTIAL_RE.fullmatch(text, cut)):
            self._pending = text[cut:]
            text = text[:cut]
        pos = 0
        for m in _TOKEN_RE.finditer(text):
            if m.start() > pos:
                self._put(text[pos:m.start()])
            self._control(m.group(0))
            pos = m.end()
        if pos < len(text):
            self._put(text[pos:])

    def _put(self, run):
        """Write printable text at the cursor, wrapping at the right edge."""
        while run:
            space = self.cols - self.col
            if space <= 0:
                self._linefeed()
                self.col = 0
                space = self.cols
            chunk = run[:space]
            line = self._grid[self.row]
            line[self.col:self.col + len(chunk)] = list(chunk)
            self.col += len(chunk)
            run = run[len(chunk):]

    def _linefeed(self):
        if self.row == self._bot:
            self._scroll_up(1)
        elif self.row < self.rows - 1:
            self.row += 1

    def _reverse_linefeed(self):
        if self.row == self._top:
            self._scroll_down(1)
        elif self.row > 0:
            self.row -= 1

    def _scroll_up(self, n):
        n = min(n, self._bot - self._top + 1)
        region = self._grid[self._top:self._bot + 1]
        self._grid[self._top:self._bot + 1] = (
            region[n:] + [self._blank_row() for _ in range(n)])

    def _scroll_down(self, n):
        n = min(n, self._bot - self._top + 1)
        region = self._grid[self._top:self._bot + 1]
        self._grid[self._top:self._bot + 1] = (
            [self._blank_row() for _ in range(n)] + region[:len(region) - n])

    def _erase_line(self, mode):
        line = self._grid[self.row]
        if mode == 1:
            end = min(self.cols, self.col + 1)
            line[:end] = [" "] * end
        elif mode == 2:
            line[:] = [" "] * self.cols
        else:
            line[self.col:] = [" "] * (self.cols - self.col)

    def _erase_display(self, mode):
        if mode == 1:
            for r in range(self.row):
                self._grid[r] = self._blank_row()
            self._erase_line(1)
        elif mode in (2, 3):
            for r in range(self.rows):
                self._grid[r] = self._blank_row()
        else:
            self._erase_line(0)
            for r in range(self.row + 1, self.rows):
                self._grid[r] = self._blank_row()

    def _insert_lines(self, n):
        if not (self._top <= self.row <= self._bot):
            return
        n = min(n, self._bot - self.row + 1)
        span = self._grid[self.row:self._bot + 1]
        self._grid[self.row:self._bot + 1] = (
            [self._blank_row() for _ in range(n)] + span[:len(span) - n])

    def _delete_lines(self, n):
        if not (self._top <= self.row <= self._bot):
            return
        n = min(n, self._bot - self.row + 1)
        span = self._grid[self.row:self._bot + 1]
        self._grid[self.row:self._bot + 1] = (
            span[n:] + [self._blank_row() for _ in range(n)])

    def _insert_chars(self, n):
        line = self._grid[self.row]
        n = min(n, self.cols - self.col)
        line[self.col:] = ([" "] * n + line[self.col:])[:self.cols - self.col]

    def _delete_chars(self, n):
        line = self._grid[self.row]
        n = min(n, self.cols - self.col)
        line[self.col:] = line[self.col + n:] + [" "] * n

    def _set_alt(self, on):
        if on and not self._on_alt:
            self._on_alt = True
            self._saved = (self.row, self.col)
            self._alt[:] = self._blank_grid()
            self._grid = self._alt
            self.row = self.col = 0
        elif not on and self._on_alt:
            self._on_alt = False
            self._grid = self._main
            self.row, self.col = self._clamped(*self._saved)

    def _control(self, seq):
        ch = seq[0]
        if ch != "\x1b":
            if ch == "\n":
                self._linefeed()
            elif ch == "\r":
                self.col = 0
            elif ch == "\b":
                self.col = max(0, self.col - 1)
            elif ch == "\t":
                self.col = min(self.cols - 1, (self.col // 8 + 1) * 8)
            return
        kind = seq[1] if len(seq) > 1 else ""
        if kind == "[":
            self._csi(seq)
        elif kind == "7":
            self._saved = (self.row, self.col)
        elif kind == "8":
            self.row, self.col = self._clamped(*self._saved)
        elif kind == "D":
            self._linefeed()
        elif kind == "E":
            self._linefeed()
            self.col = 0
        elif kind == "M":
            self._reverse_linefeed()
        elif kind == "c":
            self._grid[:] = self._blank_grid()
            self.row = self.col = 0
            self._top, self._bot = 0, self.rows - 1
        # OSC/DCS/charset selectors and the rest have no visible effect.

    def _csi(self, seq):
        final = seq[-1]
        body = seq[2:-1]
        private = body.startswith("?")
        body = body.lstrip("?>=!<").rstrip(" !\"#$%&'()*+,-./")
        params = [int(part) if part.isdigit() else 0
                  for part in body.split(";")] if body else []

        def p(i, default=1):
            value = params[i] if i < len(params) else 0
            return value if value > 0 else default

        if final == "A":
            self.row = max(0, self.row - p(0))
        elif final in "Be":
            self.row = min(self.rows - 1, self.row + p(0))
        elif final in "Ca":
            self.col = min(self.cols - 1, self.col + p(0))
        elif final == "D":
            self.col = max(0, self.col - p(0))
        elif final == "E":
            self.row = min(self.rows - 1, self.row + p(0))
            self.col = 0
        elif final == "F":
            self.row = max(0, self.row - p(0))
            self.col = 0
        elif final in "G`":
            self.col = min(self.cols - 1, max(0, p(0) - 1))
        elif final == "d":
            self.row = min(self.rows - 1, max(0, p(0) - 1))
        elif final in "Hf":
            self.row, self.col = self._clamped(p(0) - 1, p(1) - 1)
        elif final == "J":
            self._erase_display(params[0] if params else 0)
        elif final == "K":
            self._erase_line(params[0] if params else 0)
        elif final == "L":
            self._insert_lines(p(0))
        elif final == "M":
            self._delete_lines(p(0))
        elif final == "@":
            self._insert_chars(p(0))
        elif final == "P":
            self._delete_chars(p(0))
        elif final == "X":
            end = min(self.cols, self.col + p(0))
            self._grid[self.row][self.col:end] = [" "] * (end - self.col)
        elif final == "S":
            self._scroll_up(p(0))
        elif final == "T":
            self._scroll_down(p(0))
        elif final == "r":
            top = p(0) - 1
            bot = (params[1] if len(params) > 1 and params[1] else self.rows) - 1
            if 0 <= top < bot <= self.rows - 1:
                self._top, self._bot = top, bot
            else:
                self._top, self._bot = 0, self.rows - 1
            self.row = self.col = 0
        elif final in "hl" and private:
            # Only the alternate screen changes what is visible; cursor
            # visibility, bracketed paste, mouse modes etc. do not.
            if any(mode in params for mode in (47, 1047, 1049)):
                self._set_alt(final == "h")
        elif final == "s":
            self._saved = (self.row, self.col)
        elif final == "u":
            self.row, self.col = self._clamped(*self._saved)


def match_prompt_ex(tail, patterns):
    """Return (keys, matched_text) for the first matching pattern, else None.

    `matched_text` is the exact substring the pattern matched -- the menu line
    or question, but not the surrounding spinner / timer noise. It serves as a
    stable identity for the prompt so we can tell "the same prompt, still up" (a
    repaint) apart from "a different prompt" even while the rest of the screen
    keeps churning.

    `patterns` is a list of (compiled_regex, keys) pairs, as produced by
    compile_patterns.
    """
    for rx, keys in patterns:
        m = rx.search(tail)
        if m:
            return keys, m.group(0)
    return None


def match_prompt(tail, patterns):
    """Return the key(s) to send for the first matching pattern, else None.

    `patterns` is a list of (compiled_regex, keys) pairs, as produced by
    compile_patterns.
    """
    match = match_prompt_ex(tail, patterns)
    return match[0] if match is not None else None


def append_debug(path, now, tail, match):
    """Append one diagnostic record (the visible tail + match result) to `path`.

    Opt-in via the `AUTO_DEBUG` env var. When a prompt is missed, the regexes
    almost always match the expected text, so the real cause hides in what the
    screen model actually reconstructed from the PTY stream. Dumping the exact
    screen and whether it matched is what turns "auto didn't catch it" into a
    reproducible, fixable record. Never raises into the event loop: a debug
    sink that fails must not take the wrapper down with it.
    """
    try:
        sig = match[1] if match is not None else None
        verdict = f"MATCH {sig!r}" if match is not None else "NO MATCH"
        with open(path, "a", encoding="utf-8") as f:
            f.write(f"\n----- t={now:.3f} {verdict} -----\n")
            f.write(tail)
            f.write("\n")
    except OSError:
        pass


class Answerer:
    """Decides what (if anything) to send to an auto-answered tool.

    This is the shared, side-effect-free brain used by both the POSIX and the
    Windows event loops. Drive it by calling `consider(tail, now)` on every
    loop tick (after each chunk of output and, while a prompt is up, on a short
    poll). It keeps just enough state to:

    * answer a prompt once it has stayed on screen for `stable_secs`, even while
      the tool keeps repainting an animated element (a spinner, an elapsed-time
      counter, an "esc to interrupt" hint) so the screen never goes quiet -- the
      dedup key is the *matched prompt text*, which holds still through that
      churn, not the whole screen;
    * answer it exactly once, and
    * re-send the answer a bounded number of times if it never took effect.

    The last point covers a keystroke the TUI drops while repainting, which used
    to leave `auto` blocked forever; if the same prompt is still on screen a
    while after we answered, we send it again.
    """

    def __init__(self, patterns, stable_secs=IDLE_SECS,
                 retry_secs=ANSWER_RETRY_SECS, max_retries=MAX_ANSWER_RETRIES,
                 debug_path=None):
        self.patterns = patterns
        self.stable_secs = stable_secs
        self.retry_secs = retry_secs
        self.max_retries = max_retries
        # Optional diagnostic sink (the AUTO_DEBUG path). When set, each changed
        # screen is recorded with its match verdict so a missed prompt can be
        # inspected after the fact. `_last_logged` dedups identical tails.
        self.debug_path = debug_path
        self._last_logged = None
        self.reset()

    def reset(self):
        """Forget the tracked prompt; call when the user takes over a prompt."""
        self.sig = None           # matched text of the prompt currently up
        self.keys = None          # keys that answer it
        self.seen_at = 0.0        # when this prompt first appeared (monotonic)
        self.answered = False     # have we sent its answer yet?
        self.answered_at = 0.0    # when we last sent it (for re-sends)
        self.retries = 0          # re-sends issued for this prompt

    def needs_tick(self):
        """Whether the loop should keep polling (vs. block until more output).

        True while a prompt is tracked and there is still work to do for it:
        the stability window has not elapsed, or a re-send may still be due.
        """
        if self.sig is None:
            return False
        return not self.answered or self.retries < self.max_retries

    def consider(self, tail, now):
        """Inspect the current screen; return keys to send, or None.

        Tracks the prompt by its matched text. A freshly-appeared prompt is
        answered once it has held for `stable_secs`; an already-answered prompt
        that lingers is re-sent up to `max_retries` times.
        """
        match = match_prompt_ex(tail, self.patterns)
        if self.debug_path and tail != self._last_logged:
            self._last_logged = tail
            append_debug(self.debug_path, now, tail, match)
        if match is None:
            self.reset()                       # no prompt on screen anymore
            return None
        keys, sig = match
        if sig != self.sig:
            # A new (or changed) prompt: start its stability window afresh.
            self.sig = sig
            self.keys = keys
            self.seen_at = now
            self.answered = False
            self.retries = 0
            return None
        if not self.answered:
            if (now - self.seen_at) < self.stable_secs:
                return None                    # not stable long enough yet
            self.answered = True
            self.answered_at = now
            return keys
        # Already answered. If it is still up well after we answered, the
        # keystroke was likely dropped mid-redraw -- re-send, bounded.
        if self.retries >= self.max_retries:
            return None
        if (now - self.answered_at) < self.retry_secs:
            return None
        self.retries += 1
        self.answered_at = now
        return keys


def install_dir(path=None):
    """Return the directory of the real `auto` script, resolving symlinks.

    `auto` is typically installed as a symlink on the PATH pointing at a git
    checkout, so the actual repository lives at the symlink's target.
    """
    return os.path.dirname(os.path.realpath(path or __file__))


def update(repo=None, runner=subprocess.call):
    """Self-update the install with `git pull --ff-only`. Return an exit code.

    `repo` defaults to the install directory; `runner` runs the git command
    (injectable for testing). Returns 1 if `repo` is not a git checkout,
    otherwise the exit code reported by git.
    """
    repo = repo if repo is not None else install_dir()
    if not os.path.isdir(os.path.join(repo, ".git")):
        sys.stderr.write(
            f"auto: {repo!r} is not a git checkout; cannot self-update.\n"
        )
        return 1
    return runner(["git", "-C", repo, "pull", "--ff-only"])


# Matches the `__version__ = "X.Y.Z"` assignment so the version can be bumped
# in place (used by the pre-commit hook) without touching the rest of the file.
VERSION_RE = re.compile(r'(?m)^__version__\s*=\s*"(?P<v>\d+\.\d+\.\d+)"')


def bump_version(version, part="patch"):
    """Return `version` (a "MAJOR.MINOR.PATCH" string) with `part` incremented.

    Bumping major resets minor and patch to 0; bumping minor resets patch.
    """
    major, minor, patch = (int(n) for n in version.split("."))
    if part == "major":
        return f"{major + 1}.0.0"
    if part == "minor":
        return f"{major}.{minor + 1}.0"
    if part == "patch":
        return f"{major}.{minor}.{patch + 1}"
    raise ValueError(f"unknown version part: {part!r}")


def bump_source(path=None, part="patch"):
    """Increment the `__version__` string inside the `auto` source file.

    `path` defaults to this script. Returns the new version. Raises ValueError
    if no `__version__` assignment is found.
    """
    path = path if path is not None else os.path.realpath(__file__)
    with open(path, encoding="utf-8") as f:
        text = f.read()
    match = VERSION_RE.search(text)
    if match is None:
        raise ValueError(f"no __version__ string found in {path!r}")
    new_version = bump_version(match.group("v"), part)
    new_text = text[: match.start("v")] + new_version + text[match.end("v") :]
    with open(path, "w", encoding="utf-8") as f:
        f.write(new_text)
    return new_version


def get_winsize(fd):
    """Return the (rows, cols) window size of fd, defaulting to (24, 80)."""
    try:
        data = fcntl.ioctl(fd, termios.TIOCGWINSZ, b"\x00" * 8)
        rows, cols, _, _ = struct.unpack("HHHH", data)
        return rows, cols
    except OSError:
        return 24, 80


def set_winsize(fd, rows, cols):
    """Set the window size of fd to (rows, cols), ignoring errors."""
    try:
        fcntl.ioctl(fd, termios.TIOCSWINSZ, struct.pack("HHHH", rows, cols, 0, 0))
    except OSError:
        pass


def _run_posix(tool, patterns):
    """Run `tool` under a POSIX PTY, auto-answering prompts. Returns an exit code."""
    target = [tool]

    stdin_fd = sys.stdin.fileno()
    stdout_fd = sys.stdout.fileno()

    rows, cols = get_winsize(stdin_fd)

    pid, master_fd = pty.fork()
    if pid == 0:
        # ---- child process ----
        try:
            os.execvp(target[0], target)
        except OSError as e:
            sys.stderr.write(f"auto: could not run {target[0]!r}: {e}\n")
            os._exit(127)

    # ---- parent process ----
    set_winsize(master_fd, rows, cols)

    # The handler only forwards the new size to the PTY (which prompts the
    # child to repaint); the screen grid is resized in the main loop, not in
    # signal context, so a feed() in progress is never interrupted mid-update.
    pending_resize = []

    def handle_winch(signum, frame):
        r, c = get_winsize(stdin_fd)
        set_winsize(master_fd, r, c)
        pending_resize[:] = [(r, c)]

    signal.signal(signal.SIGWINCH, handle_winch)

    old_term = None
    if os.isatty(stdin_fd):
        old_term = termios.tcgetattr(stdin_fd)
        tty.setraw(stdin_fd)

    screen = Screen(rows, cols)
    # decides what to send (and when to re-send); AUTO_DEBUG records what it sees
    answerer = Answerer(patterns, debug_path=os.environ.get("AUTO_DEBUG"))
    exit_code = 0

    try:
        while True:
            # Block on IO normally, but while a prompt is being tracked poll on
            # a short tick so its stability window and re-sends advance even if
            # the tool has stopped drawing (a settled, static prompt).
            timeout = POLL_SECS if answerer.needs_tick() else None
            try:
                rlist, _, _ = select.select([stdin_fd, master_fd], [], [], timeout)
            except select.error as e:
                if e.args[0] == errno.EINTR:
                    continue  # interrupted by SIGWINCH; resume
                raise

            if pending_resize:
                screen.resize(*pending_resize.pop())

            if master_fd in rlist:
                try:
                    data = os.read(master_fd, 4096)
                except OSError:
                    data = b""
                if not data:
                    break  # child closed the PTY -> it exited
                os.write(stdout_fd, data)
                screen.feed(data)

            if stdin_fd in rlist:
                try:
                    user_in = os.read(stdin_fd, 4096)
                except OSError:
                    user_in = b""
                if user_in:
                    os.write(master_fd, user_in)
                    # the user interacted: don't fight them on the current prompt
                    answerer.reset()
                    continue

            # Inspect the screen every tick. The answerer keys on the matched
            # prompt text, so it answers a prompt that has held still long
            # enough even while a spinner keeps the rest of the screen churning.
            keys = answerer.consider(screen.text(), time.monotonic())
            if keys is not None:
                os.write(master_fd, keys)
    finally:
        if old_term is not None:
            termios.tcsetattr(stdin_fd, termios.TCSAFLUSH, old_term)
        try:
            os.close(master_fd)
        except OSError:
            pass
        # reap the child and propagate its exit code
        try:
            _, status = os.waitpid(pid, 0)
            if os.WIFEXITED(status):
                exit_code = os.WEXITSTATUS(status)
            elif os.WIFSIGNALED(status):
                exit_code = 128 + os.WTERMSIG(status)
        except OSError:
            pass

    return exit_code


# --------------------------------------------------------------------------
# Windows: ConPTY pseudoconsole, driven through ctypes (no dependencies).
# Mirrors the POSIX path: write the child's output to the real console, feed
# it into the screen model, and inspect the visible screen on every tick.
# Requires Windows 10 1809+ (the first build with the ConPTY API).
# --------------------------------------------------------------------------
if WINDOWS:
    import ctypes
    import shutil
    import threading
    from ctypes import wintypes

    _kernel32 = ctypes.WinDLL("kernel32", use_last_error=True)

    _STD_INPUT_HANDLE = 0xFFFFFFF6   # (DWORD)-10
    _STD_OUTPUT_HANDLE = 0xFFFFFFF5  # (DWORD)-11
    _ENABLE_PROCESSED_INPUT = 0x0001
    _ENABLE_LINE_INPUT = 0x0002
    _ENABLE_ECHO_INPUT = 0x0004
    _ENABLE_VIRTUAL_TERMINAL_INPUT = 0x0200
    _ENABLE_PROCESSED_OUTPUT = 0x0001
    _ENABLE_VIRTUAL_TERMINAL_PROCESSING = 0x0004
    _PROC_THREAD_ATTRIBUTE_PSEUDOCONSOLE = 0x00020016
    _EXTENDED_STARTUPINFO_PRESENT = 0x00080000
    _INFINITE = 0xFFFFFFFF
    _CP_UTF8 = 65001

    class _COORD(ctypes.Structure):
        _fields_ = [("X", wintypes.SHORT), ("Y", wintypes.SHORT)]

    class _SMALL_RECT(ctypes.Structure):
        _fields_ = [("Left", wintypes.SHORT), ("Top", wintypes.SHORT),
                    ("Right", wintypes.SHORT), ("Bottom", wintypes.SHORT)]

    class _CONSOLE_SCREEN_BUFFER_INFO(ctypes.Structure):
        _fields_ = [("dwSize", _COORD), ("dwCursorPosition", _COORD),
                    ("wAttributes", wintypes.WORD), ("srWindow", _SMALL_RECT),
                    ("dwMaximumWindowSize", _COORD)]

    class _STARTUPINFOW(ctypes.Structure):
        _fields_ = [
            ("cb", wintypes.DWORD),
            ("lpReserved", wintypes.LPWSTR),
            ("lpDesktop", wintypes.LPWSTR),
            ("lpTitle", wintypes.LPWSTR),
            ("dwX", wintypes.DWORD),
            ("dwY", wintypes.DWORD),
            ("dwXSize", wintypes.DWORD),
            ("dwYSize", wintypes.DWORD),
            ("dwXCountChars", wintypes.DWORD),
            ("dwYCountChars", wintypes.DWORD),
            ("dwFillAttribute", wintypes.DWORD),
            ("dwFlags", wintypes.DWORD),
            ("wShowWindow", wintypes.WORD),
            ("cbReserved2", wintypes.WORD),
            ("lpReserved2", ctypes.POINTER(ctypes.c_byte)),
            ("hStdInput", wintypes.HANDLE),
            ("hStdOutput", wintypes.HANDLE),
            ("hStdError", wintypes.HANDLE),
        ]

    class _STARTUPINFOEXW(ctypes.Structure):
        _fields_ = [("StartupInfo", _STARTUPINFOW),
                    ("lpAttributeList", ctypes.c_void_p)]

    class _PROCESS_INFORMATION(ctypes.Structure):
        _fields_ = [("hProcess", wintypes.HANDLE), ("hThread", wintypes.HANDLE),
                    ("dwProcessId", wintypes.DWORD), ("dwThreadId", wintypes.DWORD)]

    _kernel32.CreatePipe.argtypes = [
        ctypes.POINTER(wintypes.HANDLE), ctypes.POINTER(wintypes.HANDLE),
        ctypes.c_void_p, wintypes.DWORD]
    _kernel32.CreatePipe.restype = wintypes.BOOL
    _kernel32.ResizePseudoConsole.argtypes = [wintypes.HANDLE, _COORD]
    _kernel32.ResizePseudoConsole.restype = ctypes.c_long
    _kernel32.ClosePseudoConsole.argtypes = [wintypes.HANDLE]
    _kernel32.ClosePseudoConsole.restype = None
    _kernel32.InitializeProcThreadAttributeList.argtypes = [
        ctypes.c_void_p, wintypes.DWORD, wintypes.DWORD,
        ctypes.POINTER(ctypes.c_size_t)]
    _kernel32.InitializeProcThreadAttributeList.restype = wintypes.BOOL
    _kernel32.UpdateProcThreadAttribute.argtypes = [
        ctypes.c_void_p, wintypes.DWORD, ctypes.c_size_t, ctypes.c_void_p,
        ctypes.c_size_t, ctypes.c_void_p, ctypes.POINTER(ctypes.c_size_t)]
    _kernel32.UpdateProcThreadAttribute.restype = wintypes.BOOL
    _kernel32.DeleteProcThreadAttributeList.argtypes = [ctypes.c_void_p]
    _kernel32.DeleteProcThreadAttributeList.restype = None
    _kernel32.CreateProcessW.argtypes = [
        wintypes.LPCWSTR, wintypes.LPWSTR, ctypes.c_void_p, ctypes.c_void_p,
        wintypes.BOOL, wintypes.DWORD, ctypes.c_void_p, wintypes.LPCWSTR,
        ctypes.c_void_p, ctypes.c_void_p]
    _kernel32.CreateProcessW.restype = wintypes.BOOL
    _kernel32.ReadFile.argtypes = [
        wintypes.HANDLE, ctypes.c_void_p, wintypes.DWORD,
        ctypes.POINTER(wintypes.DWORD), ctypes.c_void_p]
    _kernel32.ReadFile.restype = wintypes.BOOL
    _kernel32.WriteFile.argtypes = [
        wintypes.HANDLE, ctypes.c_void_p, wintypes.DWORD,
        ctypes.POINTER(wintypes.DWORD), ctypes.c_void_p]
    _kernel32.WriteFile.restype = wintypes.BOOL
    _kernel32.CloseHandle.argtypes = [wintypes.HANDLE]
    _kernel32.CloseHandle.restype = wintypes.BOOL
    _kernel32.GetStdHandle.argtypes = [wintypes.DWORD]
    _kernel32.GetStdHandle.restype = wintypes.HANDLE
    _kernel32.GetConsoleMode.argtypes = [
        wintypes.HANDLE, ctypes.POINTER(wintypes.DWORD)]
    _kernel32.GetConsoleMode.restype = wintypes.BOOL
    _kernel32.SetConsoleMode.argtypes = [wintypes.HANDLE, wintypes.DWORD]
    _kernel32.SetConsoleMode.restype = wintypes.BOOL
    _kernel32.GetConsoleScreenBufferInfo.argtypes = [
        wintypes.HANDLE, ctypes.POINTER(_CONSOLE_SCREEN_BUFFER_INFO)]
    _kernel32.GetConsoleScreenBufferInfo.restype = wintypes.BOOL
    _kernel32.GetConsoleOutputCP.restype = wintypes.UINT
    _kernel32.GetConsoleCP.restype = wintypes.UINT
    _kernel32.SetConsoleOutputCP.argtypes = [wintypes.UINT]
    _kernel32.SetConsoleOutputCP.restype = wintypes.BOOL
    _kernel32.SetConsoleCP.argtypes = [wintypes.UINT]
    _kernel32.SetConsoleCP.restype = wintypes.BOOL
    _kernel32.WaitForSingleObject.argtypes = [wintypes.HANDLE, wintypes.DWORD]
    _kernel32.WaitForSingleObject.restype = wintypes.DWORD
    _kernel32.GetExitCodeProcess.argtypes = [
        wintypes.HANDLE, ctypes.POINTER(wintypes.DWORD)]
    _kernel32.GetExitCodeProcess.restype = wintypes.BOOL
    # CreatePseudoConsole takes a COORD by value; it is absent on pre-1809
    # Windows, so resolve it defensively.
    _create_pseudo_console = getattr(_kernel32, "CreatePseudoConsole", None)
    if _create_pseudo_console is not None:
        _create_pseudo_console.argtypes = [
            _COORD, wintypes.HANDLE, wintypes.HANDLE, wintypes.DWORD,
            ctypes.POINTER(wintypes.HANDLE)]
        _create_pseudo_console.restype = ctypes.c_long  # HRESULT

    def _win_winsize(stdout_h):
        """Return the (rows, cols) of the console window, defaulting to (24, 80)."""
        info = _CONSOLE_SCREEN_BUFFER_INFO()
        if _kernel32.GetConsoleScreenBufferInfo(stdout_h, ctypes.byref(info)):
            cols = info.srWindow.Right - info.srWindow.Left + 1
            rows = info.srWindow.Bottom - info.srWindow.Top + 1
            if cols > 0 and rows > 0:
                return rows, cols
        return 24, 80

    def _win_command_line(tool):
        """Resolve `tool` on PATH and build a CreateProcessW command line.

        CreateProcess does not honour PATHEXT or run .cmd/.bat shims directly
        (npm installs `claude` as a .cmd shim), so resolve with shutil.which
        and route batch shims through cmd.exe.
        """
        exe = shutil.which(tool)
        if exe is None:
            return None
        if exe.lower().endswith((".cmd", ".bat")):
            return f'cmd.exe /c "{exe}"'
        return f'"{exe}"'

    def _run_windows(tool, patterns):
        """Run `tool` under a ConPTY, auto-answering prompts. Returns an exit code."""
        if _create_pseudo_console is None:
            sys.stderr.write(
                "auto: this Windows build lacks ConPTY (needs Windows 10 1809+).\n"
            )
            return 1

        cmdline = _win_command_line(tool)
        if cmdline is None:
            sys.stderr.write(f"auto: could not run {tool!r}: not found on PATH\n")
            return 127

        stdin_h = _kernel32.GetStdHandle(_STD_INPUT_HANDLE)
        stdout_h = _kernel32.GetStdHandle(_STD_OUTPUT_HANDLE)
        rows, cols = _win_winsize(stdout_h)

        # Two pipes: one feeds keystrokes into the PTY, one carries its output.
        pty_in_read = wintypes.HANDLE()
        our_in_write = wintypes.HANDLE()
        our_out_read = wintypes.HANDLE()
        pty_out_write = wintypes.HANDLE()
        if not _kernel32.CreatePipe(
                ctypes.byref(pty_in_read), ctypes.byref(our_in_write), None, 0):
            raise ctypes.WinError(ctypes.get_last_error())
        if not _kernel32.CreatePipe(
                ctypes.byref(our_out_read), ctypes.byref(pty_out_write), None, 0):
            raise ctypes.WinError(ctypes.get_last_error())

        hpc = wintypes.HANDLE()
        hr = _create_pseudo_console(
            _COORD(cols, rows), pty_in_read, pty_out_write, 0, ctypes.byref(hpc))
        if hr != 0:
            raise OSError(f"CreatePseudoConsole failed (HRESULT 0x{hr & 0xFFFFFFFF:08x})")
        # ConPTY duplicated the PTY-side handles; closing our copies lets the
        # output read return EOF once the child exits.
        _kernel32.CloseHandle(pty_in_read)
        _kernel32.CloseHandle(pty_out_write)

        # Attach the pseudoconsole to the child via a process attribute list.
        attr_size = ctypes.c_size_t(0)
        _kernel32.InitializeProcThreadAttributeList(
            None, 1, 0, ctypes.byref(attr_size))
        attr_buf = (ctypes.c_byte * attr_size.value)()
        attr_list = ctypes.cast(attr_buf, ctypes.c_void_p)
        if not _kernel32.InitializeProcThreadAttributeList(
                attr_list, 1, 0, ctypes.byref(attr_size)):
            raise ctypes.WinError(ctypes.get_last_error())
        if not _kernel32.UpdateProcThreadAttribute(
                attr_list, 0, _PROC_THREAD_ATTRIBUTE_PSEUDOCONSOLE,
                hpc, ctypes.sizeof(wintypes.HANDLE), None, None):
            raise ctypes.WinError(ctypes.get_last_error())

        siex = _STARTUPINFOEXW()
        siex.StartupInfo.cb = ctypes.sizeof(_STARTUPINFOEXW)
        siex.lpAttributeList = attr_list
        pi = _PROCESS_INFORMATION()
        cmd_buf = ctypes.create_unicode_buffer(cmdline)
        if not _kernel32.CreateProcessW(
                None, cmd_buf, None, None, False, _EXTENDED_STARTUPINFO_PRESENT,
                None, None, ctypes.byref(siex), ctypes.byref(pi)):
            err = ctypes.get_last_error()
            _kernel32.ClosePseudoConsole(hpc)
            _kernel32.DeleteProcThreadAttributeList(attr_list)
            _kernel32.CloseHandle(our_out_read)
            _kernel32.CloseHandle(our_in_write)
            sys.stderr.write(
                f"auto: could not run {tool!r}: {ctypes.WinError(err)}\n")
            return 127

        # Put the real console into raw, VT-aware, UTF-8 mode so keystrokes are
        # forwarded byte-for-byte and the child's VT output renders correctly.
        old_in_mode = wintypes.DWORD()
        old_out_mode = wintypes.DWORD()
        have_in = bool(_kernel32.GetConsoleMode(stdin_h, ctypes.byref(old_in_mode)))
        have_out = bool(_kernel32.GetConsoleMode(stdout_h, ctypes.byref(old_out_mode)))
        old_out_cp = _kernel32.GetConsoleOutputCP()
        old_in_cp = _kernel32.GetConsoleCP()
        if have_in:
            new_in = (old_in_mode.value
                      & ~_ENABLE_LINE_INPUT
                      & ~_ENABLE_ECHO_INPUT
                      & ~_ENABLE_PROCESSED_INPUT) | _ENABLE_VIRTUAL_TERMINAL_INPUT
            _kernel32.SetConsoleMode(stdin_h, new_in)
        if have_out:
            _kernel32.SetConsoleMode(
                stdout_h, old_out_mode.value
                | _ENABLE_PROCESSED_OUTPUT | _ENABLE_VIRTUAL_TERMINAL_PROCESSING)
        _kernel32.SetConsoleOutputCP(_CP_UTF8)
        _kernel32.SetConsoleCP(_CP_UTF8)

        lock = threading.Lock()
        done = threading.Event()
        state = {"user_typed": False}
        screen = Screen(rows, cols)
        answerer = Answerer(patterns, debug_path=os.environ.get("AUTO_DEBUG"))

        def _pump_output():
            buf = (ctypes.c_char * 4096)()
            nread = wintypes.DWORD(0)
            wn = wintypes.DWORD(0)
            while True:
                ok = _kernel32.ReadFile(
                    our_out_read, buf, 4096, ctypes.byref(nread), None)
                if not ok or nread.value == 0:
                    break  # PTY closed its output -> the child exited
                data = bytes(buf[:nread.value])
                _kernel32.WriteFile(stdout_h, data, len(data), ctypes.byref(wn), None)
                with lock:
                    screen.feed(data)
            done.set()

        def _pump_input():
            buf = (ctypes.c_char * 4096)()
            nread = wintypes.DWORD(0)
            wn = wintypes.DWORD(0)
            while not done.is_set():
                ok = _kernel32.ReadFile(
                    stdin_h, buf, 4096, ctypes.byref(nread), None)
                if not ok or nread.value == 0:
                    break
                data = bytes(buf[:nread.value])
                _kernel32.WriteFile(
                    our_in_write, data, len(data), ctypes.byref(wn), None)
                # the user interacted: don't fight them on the current prompt
                with lock:
                    state["user_typed"] = True

        threading.Thread(target=_pump_output, daemon=True).start()
        threading.Thread(target=_pump_input, daemon=True).start()

        last_size = (rows, cols)
        exit_code = 0
        wn = wintypes.DWORD(0)
        try:
            while not done.is_set():
                done.wait(POLL_SECS)
                now = time.monotonic()
                with lock:
                    user_typed = state["user_typed"]
                    state["user_typed"] = False
                    tail = screen.text()
                if user_typed:
                    # the user interacted: don't fight them on the current prompt
                    answerer.reset()
                else:
                    # Inspect the screen every tick. The answerer keys on the
                    # matched prompt text, so it answers a prompt that has held
                    # still long enough even while a spinner keeps churning.
                    keys = answerer.consider(tail, now)
                    if keys is not None:
                        _kernel32.WriteFile(
                            our_in_write, keys, len(keys), ctypes.byref(wn), None)
                # propagate console resizes (Windows has no SIGWINCH)
                r, c = _win_winsize(stdout_h)
                if (r, c) != last_size:
                    last_size = (r, c)
                    _kernel32.ResizePseudoConsole(hpc, _COORD(c, r))
                    with lock:
                        screen.resize(r, c)
        finally:
            _kernel32.WaitForSingleObject(pi.hProcess, _INFINITE)
            code = wintypes.DWORD(0)
            if _kernel32.GetExitCodeProcess(pi.hProcess, ctypes.byref(code)):
                exit_code = code.value
            _kernel32.ClosePseudoConsole(hpc)
            _kernel32.DeleteProcThreadAttributeList(attr_list)
            _kernel32.CloseHandle(our_out_read)
            _kernel32.CloseHandle(our_in_write)
            _kernel32.CloseHandle(pi.hThread)
            _kernel32.CloseHandle(pi.hProcess)
            if have_in:
                _kernel32.SetConsoleMode(stdin_h, old_in_mode.value)
            if have_out:
                _kernel32.SetConsoleMode(stdout_h, old_out_mode.value)
            _kernel32.SetConsoleOutputCP(old_out_cp)
            _kernel32.SetConsoleCP(old_in_cp)

        return exit_code


def main(argv=None):
    if argv is None:
        argv = sys.argv
    tool = resolve_tool(argv)
    if tool in ("--version", "-V", "version"):
        sys.stdout.write(f"auto {__version__}\n")
        sys.exit(0)
    if tool == "update":
        sys.exit(update())
    if tool not in TOOLS:
        sys.stderr.write(
            f"auto: tool {tool!r} is not supported. "
            f"Use: {' or '.join(sorted(TOOLS))} (or 'update').\n"
        )
        sys.exit(2)

    # Announce the running version before handing the terminal to the tool.
    sys.stderr.write(f"auto {__version__}\n")
    patterns = compile_patterns(tool)
    if WINDOWS:
        sys.exit(_run_windows(tool, patterns))
    sys.exit(_run_posix(tool, patterns))


if __name__ == "__main__":
    main()
